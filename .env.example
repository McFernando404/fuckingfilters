# FuckingFilters environment variables.
# Copy this file to `.env` (or `.env.local`) and fill in the values for your
# deployment. Variables MUST be set in the host environment for production.

# Public site URL (no trailing slash). Used to resolve absolute URLs for
# OpenGraph / Twitter card images and canonical metadata. REQUIRED in
# production — if unset, social cards resolve image URLs to localhost and
# render with no preview.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Cloudflare Worker (LLM proxy) origin, WITHOUT a trailing slash. Only needed
# once the backend proxy is wired up and called directly from the browser.
# Leave unset in dev until then. Set the REAL value in the Vercel dashboard —
# never commit it. NOTE: any origin here is visible to visitors via the CSP
# response header, so a truly hidden backend must be proxied server-side.
NEXT_PUBLIC_WORKER_URL=
